#!/usr/bin/env bash
set -e
if [[ ! -d "/Users/sperber/data/active-group/schulung/isaqb/funar/funar-2026-03-hh" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/Users/sperber/data/active-group/schulung/isaqb/funar/funar-2026-03-hh")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/Users/sperber/data/active-group/schulung/isaqb/funar/funar-2026-03-hh" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/Users/sperber/data/active-group/schulung/isaqb/funar/funar-2026-03-hh/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/Users/sperber/data/active-group/schulung/isaqb/funar/funar-2026-03-hh/.envrc" "/Users/sperber/data/active-group/schulung/isaqb/funar/funar-2026-03-hh/.direnv"/*.rc
